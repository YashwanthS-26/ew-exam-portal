{
  "name": "student-client",
  "private": true,
  "version": "0.0.0",
  "author": "EW Exam Portal",
  "description": "Student Client for EW Exam Portal",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.ewexamportal.studentclient",
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "tsc -p electron/tsconfig.node.json && electron .",
    "dev": "concurrently -k \"npm run dev:react\" \"wait-on tcp:5174 && npm run dev:electron\"",
    "build:react": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.node.json",
    "build": "npm run build:react && npm run build:electron && electron-builder"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0"
  }
}
